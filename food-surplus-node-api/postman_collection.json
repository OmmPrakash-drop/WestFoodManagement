                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"MyRestaurant\",\n  \"password\": \"securepassword123\",\n  \"role\": \"RESTAURANT\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "register"
                            ]
                        }
                    },
                    "response": []
